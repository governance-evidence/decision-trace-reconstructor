    {
      "@id": "src/",
      "@type": "Dataset",
      "name": "Source code",
      "description": "Python package: six-stage reconstruction pipeline (fragment collection, temporal ordering, chain assembly, boundary detection, decision-event-schema mapping, feasibility classification) plus output writers for raw JSON, JSON Schema, W3C PROV-O JSON-LD, and Apache Parquet."
    },
    {
      "@id": "tests/",
      "@type": "Dataset",
      "name": "Test suite",
      "description": "Unit tests for output models (Pydantic round-trip), PROV-O JSON-LD emission (RDF graph validation), and Parquet writer (skipped when pyarrow unavailable)."
    },
    {
      "@id": "scripts/",
      "@type": "Dataset",
      "name": "Utility scripts",
      "description": "export_schemas.py regenerates docs/schemas/ from Pydantic models."
    },
    {
      "@id": "docs/schemas/",
      "@type": "Dataset",
      "name": "JSON Schema",
      "description": "Draft 2020-12 JSON Schema documents for the four canonical result artifacts: cells, per_property, per_scenario, named_incidents.",
      "hasPart": [
        {"@id": "docs/schemas/cells.schema.json"},
        {"@id": "docs/schemas/per_property.schema.json"},
        {"@id": "docs/schemas/per_scenario.schema.json"},
        {"@id": "docs/schemas/named_incidents.schema.json"}
      ]
    },
    {
      "@id": "results/",
      "@type": "Dataset",
      "name": "Evaluation results",
      "description": "Canonical results from the 140-scenario evaluation matrix and named-incident reconstructions. Raw JSON is wire format; PROV-O JSON-LD siblings carry the same data as queryable RDF graphs.",
